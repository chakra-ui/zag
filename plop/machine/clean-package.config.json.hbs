{
  "replace": {
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./anatomy": {
        "import": {
          "types": "./dist/{{machine}}.anatomy.d.mts",
          "default": "./dist/{{machine}}.anatomy.mjs"
        },
        "require": {
          "types": "./dist/{{machine}}.anatomy.d.ts",
          "default": "./dist/{{machine}}.anatomy.js"
        }
      },
      "./package.json": "./package.json"
    }
  }
}
